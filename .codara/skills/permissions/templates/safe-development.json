{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Edit(src/**)",
      "Write(src/**)",
      "Bash(git *)",
      "Bash(npm run *)",
      "Bash(bun run *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(*production*)"
    ]
  }
}
